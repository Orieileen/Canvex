# ╔══════════════════════════════════════════════════════════════════╗
# ║  Canvex  —  环境变量参考                                       ║
# ║  按功能分组：Chat → Image → Video → 基础设施                   ║
# ╚══════════════════════════════════════════════════════════════════╝


# ┌─────────────────────────────────────────────────────────────────┐
# │  A. Chat — 聊天链路                                            │
# │  graphs.py: load_memory → call_llm → update_memory → END       │
# └─────────────────────────────────────────────────────────────────┘

# [必填] 聊天 LLM 的 API Key
OPENAI_API_KEY=

# 聊天 LLM 的 Base URL（直连 OpenAI 可留空；兼容网关填完整地址如 https://xxx/v1）
OPENAI_BASE_URL=

# 聊天模型名称
CHAT_MODEL=gpt-4o-mini

# 聊天温度
CHAT_TEMPERATURE=0.4

# 聊天最大 token 数（留空则由模型决定）
# CHAT_MAX_TOKENS=

# --- 记忆系统 (memory.py) ---

# 摘要 TTL（秒），默认 30 天
# SUMMARY_TTL_SECONDS=2592000

# 摘要保留快照数
# SUMMARY_HISTORY_LIMIT=6

# 记忆稳定性窗口 / 最小出现次数
# MEMORY_STABILITY_WINDOW=3
# MEMORY_STABILITY_MIN_COUNT=2


# ┌─────────────────────────────────────────────────────────────────┐
# │  B. Image — 图片生成 & 编辑                                    │
# │  tools/image.py: _generate_image_media / _edit_image_media      │
# │                                                                 │
# │  两条路径：                                                     │
# │  1) OpenAI Responses API  — 不设 COMPAT_ENDPOINT 时使用         │
# │  2) Compat 兼容端点       — 设置 COMPAT_ENDPOINT 后走 HTTP 直连 │
# │     支持同步（直接返回图片）和异步（返回 task_id 后轮询）供应商  │
# └─────────────────────────────────────────────────────────────────┘

# [必填] 媒体链路 API Key（图片和视频共用）
MEDIA_API_KEY=

# [必填] 媒体链路 Base URL（图片和视频共用）
MEDIA_BASE_URL=

# 媒体链路全局超时（秒）
MEDIA_TIMEOUT=600

# Responses API 的 chat model（不走 compat 时必填）
MEDIA_RESPONSES_MODEL=gpt-5-mini

# --- B1. 生图 (imagetool) ---

# 生图模型
MEDIA_IMAGE_MODEL=gpt-image-1.5

# 兼容端点路径（填写后 = MEDIA_BASE_URL + 该路径）
# MEDIA_IMAGE_COMPAT_ENDPOINT=/images/generations

# 兼容端点尺寸字段名
# MEDIA_IMAGE_COMPAT_SIZE_FIELD=size

# --- B2. 图片编辑 (ExcalidrawImageEditJob) ---

# [必填] 编辑模型
MEDIA_IMAGE_EDIT_MODEL=gpt-image-1.5

# 兼容端点路径
# MEDIA_IMAGE_EDIT_COMPAT_ENDPOINT=/images/generations

# 兼容端点图片引用字段名（默认 image_urls，部分供应商用 image）
# MEDIA_IMAGE_EDIT_COMPAT_IMAGE_FIELD=image_urls

# 兼容端点尺寸字段名
# MEDIA_IMAGE_EDIT_COMPAT_SIZE_FIELD=size

# 兼容端点请求格式：json 或 multipart（默认 multipart）
# MEDIA_IMAGE_EDIT_COMPAT_CONTENT_TYPE=multipart

# 编辑输入保真度：high | low（仅 gpt-image-1.5 系列生效）
MEDIA_IMAGE_EDIT_INPUT_FIDELITY=high

# 编辑失败时允许退化为纯文本生图（忽略原图）：0 | 1
# IMAGE_EDIT_ALLOW_TEXT_FALLBACK=0

# --- B3. 图片轮询（异步供应商通用） ---

# 轮询端点路径（默认与创建端点相同；部分供应商轮询走不同路径如 /tasks）
# MEDIA_IMAGE_COMPAT_POLL_ENDPOINT=/tasks

# 轮询间隔（秒）
# MEDIA_IMAGE_POLL_INTERVAL=3

# 最大轮询次数
# MEDIA_IMAGE_POLL_MAX_ATTEMPTS=200

# 聊天接口等待图片工具结果的最长时间（秒），默认 1200 = 20 分钟
IMAGE_TOOL_WAIT_TIMEOUT_SECONDS=1200

# --- B4. 抠图 (cutout / rembg) ---

# CUTOUT_REMBG_ALPHA_MATTING=1
# CUTOUT_REMBG_FOREGROUND_THRESHOLD=240
# CUTOUT_REMBG_BACKGROUND_THRESHOLD=10
# CUTOUT_REMBG_ERODE_SIZE=6


# ┌─────────────────────────────────────────────────────────────────┐
# │  C. Video — 视频生成                                           │
# │  tools/video.py, tasks.py, video_script.py                      │
# │                                                                 │
# │  两条路径：                                                     │
# │  1) OpenAI SDK — 不设 COMPAT_ENDPOINT 时使用                    │
# │  2) Compat 兼容端点 — 支持 json / multipart 两种请求格式        │
# └─────────────────────────────────────────────────────────────────┘

# 视频生成模型
MEDIA_VIDEO_MODEL=sora-2

# --- C1. 兼容端点配置 ---

# 兼容端点路径（填写后 = MEDIA_BASE_URL + 该路径）
# MEDIA_VIDEO_COMPAT_ENDPOINT=/videos/generations

# 请求格式：json（默认）或 multipart
# MEDIA_VIDEO_COMPAT_CONTENT_TYPE=json

# 时长字段名（默认 duration，部分供应商用 seconds）
# MEDIA_VIDEO_COMPAT_DURATION_FIELD=duration

# 尺寸字段名（默认 aspect_ratio，部分供应商用 size）
# 值为 aspect_ratio 时发送 "16:9" 格式，值为 size 时发送 "1280x720" 格式
# MEDIA_VIDEO_COMPAT_SIZE_FIELD=aspect_ratio

# 图片引用字段名（默认 image，部分供应商用 input_reference）
# MEDIA_VIDEO_COMPAT_IMAGE_FIELD=image

# --- C2. 视频轮询 ---

# MEDIA_VIDEO_POLL_INTERVAL=5
# MEDIA_VIDEO_POLL_MAX_ATTEMPTS=360
# MEDIA_VIDEO_TIMEOUT_SECONDS=1800

# --- C3. 视频分镜脚本 ---

# 分镜脚本分析模型
MEDIA_SCRIPT_MODEL=gpt-5-mini

# 分镜分析图片参数
# MEDIA_SCRIPT_IMAGE_MAX_SIDE=1280
# MEDIA_SCRIPT_IMAGE_JPEG_QUALITY=85

# --- C4. 视频重试 ---

# VIDEO_RETRY_MAX=6
# VIDEO_RETRY_BASE_SECONDS=20
# VIDEO_RETRY_MAX_DELAY_SECONDS=180


# ┌─────────────────────────────────────────────────────────────────┐
# │  D. Frontend — Vite 构建注入                                    │
# └─────────────────────────────────────────────────────────────────┘

# 后端 API 地址
VITE_API_URL=http://localhost:28000

# Excalidraw 静态资源路径
VITE_CANVEX_ASSET_PATH=/canvex-assets/

# Workspace 标识（前后端需一致）
VITE_WORKSPACE_KEY=public
WORKSPACE_ID=public

# 前端轮询 — 图片编辑
VITE_IMAGE_EDIT_POLL_MAX_ATTEMPTS=600
VITE_IMAGE_EDIT_POLL_INTERVAL_MS=3000

# 前端轮询 — 视频
VITE_VIDEO_POLL_MAX_ATTEMPTS=600
VITE_VIDEO_POLL_INTERVAL_MS=3000

# 视频时长选项（逗号分隔，单位秒，第一个为默认值）
VITE_VIDEO_DURATION_OPTIONS=10,15,25

# 场景保存节流参数（一般无需修改）
# VITE_SCENE_SAVE_DEBOUNCE_MS=600
# VITE_SCENE_SAVE_URGENT_MS=180
# VITE_SCENE_SAVE_FORCE_FLUSH_MS=1600
# VITE_SCENE_SAVE_WATCH_INTERVAL_MS=700
# VITE_SCENE_LOCAL_CACHE_DEBOUNCE_MS=400
# VITE_SCENE_SYNC_INTERVAL_MS=5000

# 场景图片最大边长（像素）
VITE_CANVEX_MAX_SCENE_IMAGE_DIM=99999


# ┌─────────────────────────────────────────────────────────────────┐
# │  E. 基础设施 — Django / MySQL / Redis / 网络                    │
# └─────────────────────────────────────────────────────────────────┘

# --- Django ---
DJANGO_SECRET_KEY=change-me-please-if-prd
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# DJANGO_TIME_ZONE=UTC

CORS_ALLOW_ALL_ORIGINS=true
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:28000

# --- MySQL ---
MYSQL_DATABASE=canvex
MYSQL_USER=canvex
MYSQL_PASSWORD=canvex
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# --- URL / 端口映射 ---
PUBLIC_MEDIA_BASE=http://localhost:28000
INTERNAL_MEDIA_BASE=http://backend:8000

BACKEND_PORT=28000
FRONTEND_PORT=5173

# 上传大小限制（字节），默认 20MB
# DATA_UPLOAD_MAX_MEMORY_SIZE=20971520
# FILE_UPLOAD_MAX_MEMORY_SIZE=20971520
